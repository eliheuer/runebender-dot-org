---
// TEMPORARY editor-at-root (2026-06): runebender.org serves the cloud
// editor directly while the web editor is being shared for feedback.
// The real homepage moved to /home — restore it by reverting this
// commit (git mv src/pages/home.astro back to index.astro, delete
// this file's inline approach). Everything else (/docs, /cloud) is
// untouched.
//
// The page inlines the embedded editor's own index.html at build time,
// so its hashed asset references (/cloud/editor/assets/…) always match
// the currently embedded build — no drift when build-cloud-editor.sh
// refreshes it. The leading doctype is stripped because Astro adds its
// own.
import { readFileSync } from "node:fs";

const editorHtml = readFileSync(
  new URL("../../public/cloud/editor/index.html", import.meta.url),
  "utf8",
).replace(/^<!doctype html>\s*/i, "");
---

<Fragment set:html={editorHtml} />
