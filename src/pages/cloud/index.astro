---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Cloud / Runebender"
  description="Runebender cloud launch placeholder for the ComfyUI/Vue version."
>
  <main>
    <section class="cloud-hero" aria-labelledby="cloud-title">
      <p class="eyebrow">Comfy / Vue / Cloud path / Alpha</p>
      <h1 id="cloud-title">Launch cloud.</h1>
      <p class="lede">
        This is the landing point for the browser-based Runebender path. The standalone editor is
        built from <code>~/GH/repos/runebender-comfy/web</code> and published as static files
        inside this site.
      </p>
      <div class="hero-actions" aria-label="Cloud launch links">
        <a class="button primary" href="/cloud/editor/index.html">Launch editor</a>
        <a class="button secondary" href="https://github.com/eliheuer/runebender-comfy/archive/refs/heads/main.zip">Download local</a>
      </div>
    </section>

    <section class="section split-section" aria-labelledby="cloud-next-title">
      <div>
        <div class="section-kicker">Current wiring</div>
        <h2 id="cloud-next-title">Temporary, useful.</h2>
      </div>
      <div class="reference-stack">
        <table>
          <caption>Local sync</caption>
          <tbody>
            <tr>
              <th>Source</th>
              <td><code>~/GH/repos/runebender-comfy/web</code></td>
            </tr>
            <tr>
              <th>Build</th>
              <td><code>scripts/build-cloud-editor.sh</code></td>
            </tr>
            <tr>
              <th>Output</th>
              <td><code>public/cloud/editor</code></td>
            </tr>
            <tr>
              <th>Status</th>
              <td>Alpha static build. Replace or automate when the cloud app settles.</td>
            </tr>
          </tbody>
        </table>

        <table>
          <caption>Intent</caption>
          <tbody>
            <tr>
              <th>Download local</th>
              <td>Gets users to the Comfy source for local testing.</td>
            </tr>
            <tr>
              <th>Launch cloud</th>
              <td>Opens the current standalone Vue/WASM build.</td>
            </tr>
            <tr>
              <th>Docs</th>
              <td>Keep exact setup details in the source repo until the workflow is stable.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</BaseLayout>
