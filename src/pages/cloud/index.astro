---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Cloud / Runebender"
  description="Runebender browser editor entry point."
>
  <main>
    <section class="cloud-hero" aria-labelledby="cloud-title">
      <p class="eyebrow">Browser editor / Static build / Alpha</p>
      <h1 id="cloud-title">Cloud editor.</h1>
      <p class="lede">
        A static browser build is available for quick experiments with the ComfyUI/Vue front-end.
        Runebender Xilem, Runebender Comfy, and future front-ends should be understood as related
        hosts around shared Runebender editing work.
      </p>
      <div class="hero-actions" aria-label="Cloud launch links">
        <a class="button primary" href="/cloud/editor/index.html">Launch editor</a>
        <a class="button secondary" href="/docs/current-facts.html">Current facts</a>
      </div>
    </section>

    <section class="section split-section" aria-labelledby="cloud-next-title">
      <div>
        <div class="section-kicker">Current status</div>
        <h2 id="cloud-next-title">Useful, not the whole project.</h2>
      </div>
      <div class="reference-stack">
        <table>
          <caption>Static artifact</caption>
          <tbody>
            <tr>
              <th>Launch</th>
              <td><a href="/cloud/editor/index.html">/cloud/editor/index.html</a></td>
            </tr>
            <tr>
              <th>Build</th>
              <td><code>scripts/build-cloud-editor.sh</code></td>
            </tr>
            <tr>
              <th>Output</th>
              <td><code>public/cloud/editor</code></td>
            </tr>
            <tr>
              <th>Status</th>
              <td>Alpha static build. Treat behavior as experimental.</td>
            </tr>
          </tbody>
        </table>

        <table>
          <caption>Use it for</caption>
          <tbody>
            <tr>
              <th>Quick checks</th>
              <td>Open the browser editor without setting up the desktop source tree.</td>
            </tr>
            <tr>
              <th>Real work</th>
              <td>Choose the front-end that matches the host you want, and keep UFO sources version-controlled.</td>
            </tr>
            <tr>
              <th>Docs</th>
              <td>Use the alpha docs for current status, limits, and canonical source links.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</BaseLayout>
