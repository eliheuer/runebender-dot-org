---
type NavLink = { href: string; label: string; external?: boolean; action?: boolean };

const links: NavLink[] = [
  { href: "/#family", label: "Family" },
  { href: "/docs/index.html", label: "Docs" },
  { href: "/cloud/index.html", label: "Cloud" },
  { href: "/docs/support.html", label: "Support" },
  {
    href: "/#resources",
    label: "Source",
    action: true,
  },
];

const current = Astro.url.pathname.replace(/\/$/, "") || "/";
const isCurrent = (href: string) => {
  if (href.startsWith("http")) return false;
  const target = href.replace(/\/$/, "") || "/";
  return target === current;
};
---

<header class="site-header">
  <a class="brand" href="/" aria-label="Runebender home">
    <span class="brand-mark">RB</span>
    <span>Runebender</span>
  </a>
  <nav aria-label="Primary navigation">
    {
      links.map(({ href, label, action, external }) => (
        <a
          href={href}
          class={action ? "nav-action" : undefined}
          aria-current={isCurrent(href) ? "page" : undefined}
          target={external ? "_blank" : undefined}
          rel={external ? "noreferrer" : undefined}
        >
          {label}
        </a>
      ))
    }
  </nav>
</header>
